        bytes32 promptFingerprint;
        bytes32 modelAttestation;
        bytes32 moderationHash;
    }

    struct ProfilePulse {
        uint64 lastSubmitAt;
        uint32 dailySubmitCount;
        uint64 dailyBucket;
        uint128 pendingWithdrawWei;
        uint64 memeNonce;
    }

